{
  "name": "FLUX / SDXL Image Generation",
  "type": "image",
  "description": "High-Quality Text-to-Image Generation workflow using FLUX / SDXL in ComfyUI",
  "workflow": {
    "1": {
      "inputs": {
        "text": "cinematic photorealistic portrait of a female astronaut on Mars, dramatic lighting, 8k resolution",
        "clip": [ "2", 0 ]
      },
      "class_type": "CLIPTextEncode",
      "_meta": { "title": "Positive Prompt" }
    },
    "2": {
      "inputs": {
        "clip_name": "t5xxl_fp16.safetensors"
      },
      "class_type": "CLIPLoader",
      "_meta": { "title": "Load CLIP" }
    },
    "3": {
      "inputs": {
        "seed": 987654,
        "steps": 20,
        "cfg": 3.5,
        "sampler_name": "euler",
        "scheduler": "simple",
        "denoise": 1.0,
        "model": [ "4", 0 ],
        "positive": [ "1", 0 ],
        "latent_image": [ "5", 0 ]
      },
      "class_type": "KSampler",
      "_meta": { "title": "KSampler" }
    },
    "4": {
      "inputs": {
        "unet_name": "flux1-dev.safetensors",
        "weight_dtype": "default"
      },
      "class_type": "UNETLoader",
      "_meta": { "title": "Load Diffusion Model" }
    },
    "5": {
      "inputs": {
        "width": 1024,
        "height": 1024,
        "batch_size": 1
      },
      "class_type": "EmptyLatentImage",
      "_meta": { "title": "Empty Latent Image" }
    },
    "6": {
      "inputs": {
        "samples": [ "3", 0 ],
        "vae": [ "7", 0 ]
      },
      "class_type": "VAEDecode",
      "_meta": { "title": "VAE Decode" }
    },
    "7": {
      "inputs": {
        "vae_name": "ae.safetensors"
      },
      "class_type": "VAELoader",
      "_meta": { "title": "Load VAE" }
    },
    "8": {
      "inputs": {
        "filename_prefix": "ComfyUI_FLUX",
        "images": [ "6", 0 ]
      },
      "class_type": "SaveImage",
      "_meta": { "title": "Save Image" }
    }
  }
}
